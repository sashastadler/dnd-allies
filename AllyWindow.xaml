<Window x:Class="dnd_allies.AllyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ally Selection" Height="500" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Name="NameTextBlock" Text="{Binding Name}" FontSize="16" FontWeight="Bold" Margin="10" Grid.Row="0"/>
        <TextBlock Name="DescriptionTextBlock" Text="{Binding Description}" Margin="10" Grid.Row="1"/>
        <TextBlock Name="AcTextBlock" Text="{Binding Ac}" Margin="10" Grid.Row="2"/>
        <TextBlock Name="SpeedTextBlock" Text="{Binding Speed}" Margin="10" Grid.Row="3"/>
        <TextBlock Name="ImmunitiesTextBlock" Text="{Binding Immunities}" Margin="10" Grid.Row="4"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="btnExit" Content="Exit" Height="30" Width="100" 
                    Click="ExitButton_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
