<Window x:Class="dnd_allies.AllyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ally Selection" Height="500" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Name="NameTextBlock" FontSize="24" FontWeight="Bold" Margin="10" HorizontalAlignment="Center"
                Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap"/>
        <TextBlock Name="DescriptionTextBlock" Margin="10" Grid.Row="1" Grid.Column="0" TextWrapping="Wrap"/>
        <TextBlock Name="AcTextBlock" Margin="10" Grid.Row="2" Grid.Column="0"/>
        <TextBlock Name="SpeedTextBlock" Margin="10" Grid.Row="3" Grid.Column="0"/>
        <TextBlock Name="ImmunitiesTextBlock" Margin="10" Grid.Row="4" Grid.Column="0" TextWrapping="Wrap"/>

        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="4" BorderBrush="Gray" BorderThickness="2" 
                Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Name="HpTextBlock" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
                <TextBox Name="DamageInput" Width="100" Height="25" HorizontalAlignment="Center" 
                         Margin="5" Text="0"/>
                <Button Name="DamageButton" Content="Take Damage" Width="80" Height="30" 
                        HorizontalAlignment="Center" Margin="5" Click="DamageButton_Click"/>
                <Button Name="HealButton" Content="Heal" Width="80" Height="30" 
                        HorizontalAlignment="Center" Margin="5" Click="HealButton_Click"/>
            </StackPanel>
        </Border>


        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="btnExit" Content="Exit" Height="30" Width="100" 
                    Click="ExitButton_Click" Margin="5" Grid.ColumnSpan="2"/>
        </StackPanel>
    </Grid>
</Window>
