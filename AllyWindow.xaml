<Window x:Class="dnd_allies.AllyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ally Selection" Height="500" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Ally Screen" FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10" Grid.Row="0"/>
        
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="btnExit" Content="Exit" Height="30" Width="100" 
                    Click="ExitButton_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
